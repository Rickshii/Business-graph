datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String
  name              String
  role              String     @default("ANALYST") // ADMIN, ANALYST, VIEWER
  status            String     @default("ACTIVE")  // ACTIVE, SUSPENDED
  resetToken        String?    // Plain token stored for lookup (short-lived)
  resetTokenExpiry  DateTime?  // Expiry timestamp (1 hour from generation)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  auditLogs         AuditLog[]
}

model Node {
  id         String   @id @default(uuid())
  label      String   // E.g., "Google", "Alice Smith"
  type       String   // E.g., "BUSINESS", "CUSTOMER", "SUPPLIER", "INFLUENCER", "COMPETITOR", "REVIEW"
  properties String   // JSON string representing attributes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Edge {
  id         String   @id @default(uuid())
  sourceId   String
  targetId   String
  type       String   // E.g., "BUYS_FROM", "SUPPLIES", "INFLUENCES", "COMPETES", "REVIEWS"
  weight     Float    @default(1.0)
  properties String   // JSON string representing attributes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sourceId, targetId, type])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  createdAt DateTime @default(now())
}

model SystemNotification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, ALERT
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
