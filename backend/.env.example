# ─── PostgreSQL (Prisma) ───────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/brgi_db

# ─── Neo4j (optional — omit to use local fallback engine) ──────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ─── Authentication ────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production

# ─── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (or * for any)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://business-graph.vercel.app,https://business-graph-j8tj.onrender.com

# ─── Frontend URL (used in password reset emails) ─────────────
FRONTEND_URL=https://business-graph.vercel.app

# ─── SMTP (optional — for real email delivery) ────────────────
# Leave blank to use dev-mode token response instead of email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=BRGI <noreply@brgi.com>
